# Copy to .env (or export these) before running the AI service.
# Run uvicorn with --port 8081 — the Go gateway is the front door on 8080 and
# reverse-proxies the analyze + RAG endpoints here.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=handayani

# MUST match the NYAMPE Go service's JWT_SECRET so this service can validate
# the token Go forwards on /analyze, and so the service token RAG mints is
# accepted by Go. The Go dev fallback is "super-secret-key-default".
JWT_SECRET=super-secret-key-default

# Gemini 2.5 session analysis. Leave GEMINI_API_KEY blank to use the built-in
# deterministic stub (no external calls).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Go gateway address. RAG logs in here (/api/login) and fetches the instructor
# list (/api/admin/instructors). In Docker use http://attendance:8080.
GO_BACKEND_URL=http://localhost:8080

# Manager service account used by the RAG knowledge-sync to fetch the instructor
# list from the Go service. Leave blank to omit the instructor section.
RAG_SERVICE_USERNAME=
RAG_SERVICE_PASSWORD=
